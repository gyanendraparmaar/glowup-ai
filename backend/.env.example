# GlowUp AI - Hinge Profile Reviewer Environment Variables

# 1. Groq API Key (Required for Stage 1: Vision Extraction)
# Get yours here: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# 2. Gemini API Key (Required for Stage 2: Strategic Review)
# Get yours here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Comma separated list of keys if you want basic load balancing
# GEMINI_API_KEYS=key1,key2,key3
